{
  "name": "youdesign",
  "version": "1.0.7",
  "description": "YOUDESIGN social cover designer desktop app.",
  "author": "YOUXIAKE",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "tauri dev",
    "dev": "tauri dev",
    "build": "tauri build --bundles app",
    "build:mac": "tauri build --bundles app",
    "build:mac:x64": "tauri build --bundles app",
    "build:mac:arm": "tauri build --target aarch64-apple-darwin --bundles app",
    "build:mac:dmg": "tauri build --bundles dmg",
    "build:win": "tauri build --bundles nsis",
    "build:all": "tauri build --bundles all",
    "tauri": "tauri",
    "tauri:prepare": "node scripts/prepare-tauri-dist.js",
    "tauri:local-update-manifest": "node scripts/create-local-update-manifest.js",
    "electron:start": "electron .",
    "electron:build": "electron-builder",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.youxiake.youdesign",
    "productName": "YOUDESIGN",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kim-wing",
        "repo": "social-cover-designer"
      }
    ],
    "files": [
      "index.html",
      "build/icon.*",
      "logo/**/*",
      "游小侠/**/*",
      "desktop/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
